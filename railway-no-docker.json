{
  "build": {
    "builder": "NIXPACKS"
  },
  "deploy": {
    "startCommand": "python railway_startup.py",
    "healthcheckPath": "/api/health/",
    "healthcheckTimeout": 100,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  },
  "cron": {
    "daily-tasks": {
      "schedule": "0 21 * * *",
      "command": "python manage.py send_daily_tasks"
    },
    "rotem-monitoring-cache-upsert": {
      "schedule": "*/10 * * * *",
      "command": "python manage.py upsert_monitoring_cache"
    }
  }
}
