# Full local stack: frontend + backend + Postgres + Redis
# Copy to .env.local-backend if you need machine-specific overrides.

# Host ports
FRONTEND_HOST_PORT=3002
BACKEND_HOST_PORT=8002
POSTGRES_HOST_PORT=5433
REDIS_HOST_PORT=6380

# Frontend
REACT_APP_API_URL=http://localhost:8002/api
FRONTEND_URL=http://localhost:3002
CHOKIDAR_USEPOLLING=true
NODE_OPTIONS=--max-old-space-size=4096
GENERATE_SOURCEMAP=false

# Backend runtime (same variable shape as production)
DEBUG=True
SECRET_KEY=django-insecure-local-development-key
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:3002,http://127.0.0.1:3002
CSRF_TRUSTED_ORIGINS=http://localhost:3002,http://127.0.0.1:3002

# Local Postgres + production-style database URL
POSTGRES_DB=chicken_management
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
DATABASE_URL=postgresql://postgres:password@db:5432/chicken_management
DB_CONN_MAX_AGE=0
DB_CONNECT_TIMEOUT=15
DB_STATEMENT_TIMEOUT_MS=30000
DB_POOL_MODE=session

# Local bootstrap admin
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
ADMIN_EMAIL=admin@chickenmanagement.com

# Local-safe email defaults; leave password empty to avoid using real credentials locally.
EMAIL_HOST=smtp.resend.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=resend
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@chickenmanagement.com

# Optional integrations
ROTEM_USERNAME=
ROTEM_PASSWORD=
